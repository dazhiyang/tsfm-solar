# .gitignore for Zero-Shot Solar Forecasting Benchmark

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.env/
.venv/

# ========== DATA FILES ==========
# Large raw data files that can be downloaded (~GBs)
# SURFRAD raw .dat files (very large, can be downloaded from NOAA)
# Exclude all files in SURFRAD directories, except .gitkeep
Data/SURFRAD/**/*.dat
Data/SURFRAD/**/*.dat.gz
Data/SURFRAD/**/*
!Data/SURFRAD/.gitkeep

# NSRDB downloads (large, can be re-downloaded from NREL API)
# Exclude all files in NSRDB directories, except .gitkeep
Data/NSRDB/**/*.csv
Data/NSRDB/**/*
!Data/NSRDB/.gitkeep

# ========== LaTeX GENERATED FILES ==========
# LaTeX compilation artifacts
tex/*.aux
tex/*.bbl
tex/*.blg
tex/*.log
tex/*.out
tex/*.toc
tex/*.lof
tex/*.lot
tex/*.fls
tex/*.fdb_latexmk
tex/*.synctex.gz
tex/*.spl
tex/*.nlo

# PDFs (can be regenerated by compiling LaTeX)
tex/*.pdf

# ========== OTHER ==========
# Word documents (not needed for code)
*.docx

# Temporary files
*.tmp
*.temp

# Logs
*.log

# MyPy cache
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# PyCharm
.idea/

# VS Code
.vscode/

# macOS
.DS_Store

# Windows
desktop.ini