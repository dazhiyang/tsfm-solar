# .gitignore for Zero-Shot Solar Forecasting Benchmark

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.env/
.venv/

# ========== DATA FILES ==========
# Large raw data files that can be downloaded (~GBs)
# SURFRAD raw .dat files (very large, can be downloaded from NOAA)
# Exclude all files in SURFRAD directories
Data/SURFRAD/**/*.dat
Data/SURFRAD/**/*.dat.gz
Data/SURFRAD/**/*

# NSRDB downloads (large, can be re-downloaded from NREL API)
# Exclude all files in NSRDB directories
Data/NSRDB/**/*.csv
Data/NSRDB/**/*

# ========== LaTeX FILES ==========
# Exclude all files in tex/ except:
# - overall_mbe.tex, overall_rmse.tex, overall_skill.tex
# - *_monthly.pdf files
#
# First, exclude everything in tex/
tex/*

# Then, include the specific files we want to keep
!tex/overall_mbe.tex
!tex/overall_rmse.tex
!tex/overall_skill.tex
!tex/*_monthly.pdf

# ========== OTHER ==========
# Word documents (not needed for code)
*.docx

# Temporary files
*.tmp
*.temp

# Logs
*.log

# MyPy cache
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# PyCharm
.idea/

# VS Code
.vscode/

# macOS
.DS_Store

# Windows
desktop.ini